<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Employee Census</label>
    <pluralLabel>Employee Census Records</pluralLabel>
    <nameField>
        <label>Employee ID</label>
        <type>Text</type>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ControlledByParent</sharingModel>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableHistory>false</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>false</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <fields>
        <fullName>Employer__c</fullName>
        <label>Employer</label>
        <type>MasterDetail</type>
        <referenceTo>DD_Employer__c</referenceTo>
        <relationshipLabel>Census Records</relationshipLabel>
        <relationshipName>Census_Records</relationshipName>
        <reparentableMasterDetail>false</reparentableMasterDetail>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
        <inlineHelpText>Employer this census record belongs to</inlineHelpText>
    </fields>
    <fields>
        <fullName>Date_of_Birth__c</fullName>
        <label>Date of Birth</label>
        <type>Date</type>
        <required>false</required>
        <inlineHelpText>Employee date of birth (encrypted - HIPAA PHI)</inlineHelpText>
    </fields>
    <fields>
        <fullName>Gender__c</fullName>
        <label>Gender</label>
        <type>Picklist</type>
        <required>false</required>
        <inlineHelpText>Employee gender</inlineHelpText>
        <valueSet>
            <restricted>false</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Male</fullName><label>Male</label><default>false</default></value>
                <value><fullName>Female</fullName><label>Female</label><default>false</default></value>
                <value><fullName>Non-Binary</fullName><label>Non-Binary</label><default>false</default></value>
                <value><fullName>Prefer Not to Say</fullName><label>Prefer Not to Say</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Coverage_Tier__c</fullName>
        <label>Coverage Tier</label>
        <type>Picklist</type>
        <required>false</required>
        <inlineHelpText>Selected coverage tier for this employee</inlineHelpText>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>EO</fullName><label>Employee Only</label><default>false</default></value>
                <value><fullName>ES</fullName><label>Employee + Spouse</label><default>false</default></value>
                <value><fullName>EC</fullName><label>Employee + Child(ren)</label><default>false</default></value>
                <value><fullName>EF</fullName><label>Employee + Family</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>ZIP_Code__c</fullName>
        <label>ZIP Code</label>
        <type>Text</type>
        <length>5</length>
        <required>false</required>
        <inlineHelpText>Employee residential ZIP code</inlineHelpText>
    </fields>
    <fields>
        <fullName>Status__c</fullName>
        <label>Status</label>
        <type>Picklist</type>
        <required>false</required>
        <inlineHelpText>Employee enrollment status</inlineHelpText>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Active</fullName><label>Active</label><default>true</default></value>
                <value><fullName>Waiving</fullName><label>Waiving Coverage</label><default>false</default></value>
                <value><fullName>COBRA</fullName><label>COBRA</label><default>false</default></value>
                <value><fullName>Terminated</fullName><label>Terminated</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Waiver_Reason__c</fullName>
        <label>Waiver Reason</label>
        <type>Picklist</type>
        <required>false</required>
        <inlineHelpText>Reason employee is waiving coverage</inlineHelpText>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Covered by Spouse</fullName><label>Covered by Spouse/Domestic Partner</label><default>false</default></value>
                <value><fullName>Covered by Other Employer</fullName><label>Covered by Other Employer</label><default>false</default></value>
                <value><fullName>Medicare/Medicaid</fullName><label>Medicare/Medicaid</label><default>false</default></value>
                <value><fullName>Declined Coverage</fullName><label>Declined Coverage</label><default>false</default></value>
                <value><fullName>Other</fullName><label>Other</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Dependents_Count__c</fullName>
        <label>Dependents Count</label>
        <type>Number</type>
        <precision>2</precision>
        <scale>0</scale>
        <required>false</required>
        <inlineHelpText>Number of dependents enrolled with this employee</inlineHelpText>
    </fields>
</CustomObject>
