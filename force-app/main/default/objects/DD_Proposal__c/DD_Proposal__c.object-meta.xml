<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Proposal</label>
    <pluralLabel>Proposals</pluralLabel>
    <nameField>
        <label>Proposal Number</label>
        <type>AutoNumber</type>
        <startingNumber>1</startingNumber>
        <displayFormat>PR-{000000}</displayFormat>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <fields>
        <fullName>Quote__c</fullName>
        <label>Source Quote</label>
        <type>Lookup</type>
        <referenceTo>DD_Quote__c</referenceTo>
        <relationshipLabel>Proposals</relationshipLabel>
        <relationshipName>Proposals</relationshipName>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <inlineHelpText>Quote this proposal was generated from</inlineHelpText>
    </fields>
    <fields>
        <fullName>Employer__c</fullName>
        <label>Employer</label>
        <type>Lookup</type>
        <referenceTo>DD_Employer__c</referenceTo>
        <relationshipLabel>Proposals</relationshipLabel>
        <relationshipName>Proposals</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <inlineHelpText>Employer this proposal is for</inlineHelpText>
    </fields>
    <fields>
        <fullName>Status__c</fullName>
        <label>Status</label>
        <type>Picklist</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <inlineHelpText>Current status of this proposal</inlineHelpText>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Draft</fullName><label>Draft</label><default>true</default></value>
                <value><fullName>Sent</fullName><label>Sent to Employer</label><default>false</default></value>
                <value><fullName>Viewed</fullName><label>Viewed</label><default>false</default></value>
                <value><fullName>Accepted</fullName><label>Accepted</label><default>false</default></value>
                <value><fullName>Declined</fullName><label>Declined</label><default>false</default></value>
                <value><fullName>Expired</fullName><label>Expired</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Sent_Date__c</fullName>
        <label>Date Sent</label>
        <type>Date</type>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <inlineHelpText>Date the proposal was sent to the employer or broker</inlineHelpText>
    </fields>
    <fields>
        <fullName>Expiration_Date__c</fullName>
        <label>Proposal Expiration Date</label>
        <type>Date</type>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <inlineHelpText>Date after which this proposal is no longer valid</inlineHelpText>
    </fields>
    <fields>
        <fullName>PDF_Content_Version__c</fullName>
        <label>PDF Content Version ID</label>
        <type>Text</type>
        <length>18</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <inlineHelpText>Salesforce Files ContentVersion ID of the proposal PDF</inlineHelpText>
    </fields>
    <fields>
        <fullName>Presented_By__c</fullName>
        <label>Presented By</label>
        <type>Lookup</type>
        <referenceTo>User</referenceTo>
        <relationshipLabel>Proposals Presented</relationshipLabel>
        <relationshipName>Proposals_Presented</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <inlineHelpText>Sales rep or broker who presented this proposal</inlineHelpText>
    </fields>
    <fields>
        <fullName>Notes__c</fullName>
        <label>Notes</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>4</visibleLines>
        <required>false</required>
        <inlineHelpText>Internal notes about this proposal</inlineHelpText>
    </fields>
    <fields>
        <fullName>Total_Monthly_Premium__c</fullName>
        <label>Total Monthly Premium</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>2</scale>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <inlineHelpText>Total monthly premium as quoted in this proposal</inlineHelpText>
    </fields>
    <searchLayouts>
        <searchResultsAdditionalFields>Employer__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Status__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Sent_Date__c</searchResultsAdditionalFields>
    </searchLayouts>
</CustomObject>
