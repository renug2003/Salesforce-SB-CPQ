<apex:page controller="DD_ProposalPDFController"
    renderAs="pdf"
    applyHtmlTag="false"
    showHeader="false"
    sidebar="false"
    standardStylesheets="false">
<html>
<head>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: Arial, Helvetica, sans-serif; font-size: 9pt; color: #222; background: #fff; }

  /* ── HEADER ── */
  .header { background: #006B3C; padding: 16px 24px; }
  .header-table { width: 100%; border-collapse: collapse; }
  .header-logo-cell { vertical-align: middle; width: 50%; }
  .header-title-cell { vertical-align: middle; width: 50%; text-align: right; }
  .logo-mark { font-size: 22pt; color: #fff; font-weight: 900; letter-spacing: -1px; }
  .logo-triangle { color: #8BC34A; font-size: 20pt; margin-right: 4px; }
  .logo-name { font-size: 13pt; font-weight: 800; color: #fff; letter-spacing: 0.5px; }
  .logo-state { display: block; font-size: 8pt; color: rgba(255,255,255,0.8); font-weight: 400; margin-top: 1px; }
  .doc-title { font-size: 14pt; font-weight: 700; color: #fff; }
  .doc-sub { font-size: 8pt; color: rgba(255,255,255,0.8); margin-top: 3px; }

  /* ── ACCENT BAR ── */
  .accent-bar { background: #8BC34A; height: 5px; }

  /* ── SECTION ── */
  .section { margin: 12px 24px; }
  .section-title {
    font-size: 8pt; font-weight: 800; color: #006B3C;
    text-transform: uppercase; letter-spacing: 0.8px;
    border-bottom: 2px solid #006B3C; padding-bottom: 4px; margin-bottom: 8px;
  }

  /* ── INFO GRID ── */
  .info-table { width: 100%; border-collapse: collapse; }
  .info-table td { padding: 4px 6px; vertical-align: top; width: 25%; }
  .info-label { font-size: 7pt; color: #666; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 2px; }
  .info-value { font-size: 9pt; color: #111; font-weight: 600; }

  /* ── PREMIUM BOXES ── */
  .prem-table { width: 100%; border-collapse: separate; border-spacing: 5px; }
  .prem-table td { padding: 10px; text-align: center; border-radius: 4px; }
  .prem-total { background: #006B3C; color: #fff; }
  .prem-employer { background: #2E7D32; color: #fff; }
  .prem-employee { background: #388E3C; color: #fff; }
  .prem-annual { background: #C89B2A; color: #fff; }
  .prem-label { font-size: 7pt; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 5px; opacity: 0.9; }
  .prem-amount { font-size: 14pt; font-weight: 800; }
  .prem-sub { font-size: 7pt; margin-top: 3px; opacity: 0.8; }

  /* ── PLAN SECTION ── */
  .plan-box { margin: 0 24px 14px; }
  .plan-name { font-size: 11pt; font-weight: 700; color: #006B3C; margin-bottom: 6px; }
  .plan-attrs { width: 100%; border-collapse: collapse; margin-bottom: 8px; background: #F1F8F1; border-radius: 3px; }
  .plan-attrs td { padding: 5px 8px; }
  .attr-label { font-size: 7pt; color: #555; font-weight: 700; text-transform: uppercase; display: block; }
  .attr-value { font-size: 8.5pt; font-weight: 600; color: #222; }

  /* ── RATE TABLE ── */
  .rate-tbl { width: 100%; border-collapse: collapse; font-size: 8.5pt; }
  .rate-tbl th {
    background: #006B3C; color: #fff; padding: 6px 8px;
    text-align: left; font-size: 7.5pt; text-transform: uppercase; letter-spacing: 0.3px;
  }
  .rate-tbl th.rt { text-align: right; }
  .rate-tbl td { padding: 5px 8px; border-bottom: 1px solid #E8F5E9; }
  .rate-tbl td.rt { text-align: right; }
  .rate-tbl tr:nth-child(even) td { background: #F9FFF9; }
  .rate-tbl tr.plan-total td {
    background: #E8F5E9; font-weight: 700; border-top: 2px solid #006B3C;
  }
  .emp-cost { color: #2E7D32; font-weight: 700; }

  /* ── NOTES ── */
  .notes-box {
    background: #F9FFF9; border-left: 4px solid #8BC34A;
    padding: 8px 12px; font-size: 8.5pt; color: #444; margin: 0 24px 12px;
  }

  /* ── FOOTER ── */
  .footer { margin: 8px 24px 0; border-top: 1px solid #ccc; padding-top: 8px; }
  .footer-legal { font-size: 7pt; color: #777; line-height: 1.5; }
  .footer-ref { font-size: 7pt; color: #aaa; margin-top: 4px; }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <table class="header-table">
    <tr>
      <td class="header-logo-cell">
        <span class="logo-triangle">&#9651;</span><span class="logo-name">DELTA DENTAL</span>
        <span class="logo-state">of California</span>
      </td>
      <td class="header-title-cell">
        <div class="doc-title">Group Benefits Proposal</div>
        <div class="doc-sub">Quote #<apex:outputText value="{!quote.Name}"/> &bull; Prepared <apex:outputText value="{!todayFormatted}"/></div>
      </td>
    </tr>
  </table>
</div>
<div class="accent-bar"></div>

<!-- EMPLOYER & QUOTE INFO -->
<div class="section">
  <div class="section-title">Employer &amp; Quote Information</div>
  <table class="info-table">
    <tr>
      <td>
        <div class="info-label">Employer</div>
        <div class="info-value"><apex:outputText value="{!quote.Employer__r.Name}"/></div>
      </td>
      <td>
        <div class="info-label">DBA Name</div>
        <div class="info-value">
          <apex:outputText value="{!IF(ISBLANK(quote.Employer__r.DBA_Name__c), '—', quote.Employer__r.DBA_Name__c)}"/>
        </div>
      </td>
      <td>
        <div class="info-label">ZIP Code</div>
        <div class="info-value"><apex:outputText value="{!IF(ISBLANK(quote.ZIP_Code__c), '—', quote.ZIP_Code__c)}"/></div>
      </td>
      <td>
        <div class="info-label">SIC Code</div>
        <div class="info-value">
          <apex:outputText value="{!IF(ISBLANK(quote.Employer__r.SIC_Code__c), '—', quote.Employer__r.SIC_Code__c)}"/>
        </div>
      </td>
    </tr>
    <tr>
      <td>
        <div class="info-label">Effective Date</div>
        <div class="info-value">
          <apex:outputText value="{0, date, MMMM d, yyyy}">
            <apex:param value="{!quote.Effective_Date__c}"/>
          </apex:outputText>
        </div>
      </td>
      <td>
        <div class="info-label">Total Employees</div>
        <div class="info-value"><apex:outputText value="{!TEXT(quote.Employee_Count__c)}"/></div>
      </td>
      <td>
        <div class="info-label">Rate Territory</div>
        <div class="info-value"><apex:outputText value="{!IF(ISBLANK(quote.Rate_Territory__c), 'DEFAULT', quote.Rate_Territory__c)}"/></div>
      </td>
      <td>
        <div class="info-label">Quote Expires</div>
        <div class="info-value"><apex:outputText value="{!expirationFormatted}"/></div>
      </td>
    </tr>
    <apex:outputPanel layout="block" rendered="{!NOT(ISBLANK(quote.Broker_Account__r.Name))}">
    <tr>
      <td>
        <div class="info-label">Broker / Producer</div>
        <div class="info-value"><apex:outputText value="{!quote.Broker_Account__r.Name}"/></div>
      </td>
      <td>
        <div class="info-label">Broker Phone</div>
        <div class="info-value"><apex:outputText value="{!IF(ISBLANK(quote.Broker_Account__r.Phone), '—', quote.Broker_Account__r.Phone)}"/></div>
      </td>
      <td></td><td></td>
    </tr>
    </apex:outputPanel>
  </table>
</div>

<!-- PREMIUM SUMMARY -->
<div class="section">
  <div class="section-title">Premium Summary</div>
  <table class="prem-table">
    <tr>
      <td class="prem-total">
        <div class="prem-label">Total Monthly Premium</div>
        <div class="prem-amount">
          $<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!quote.Total_Monthly_Premium__c}"/></apex:outputText>
        </div>
      </td>
      <td class="prem-employer">
        <div class="prem-label">Employer Monthly Cost</div>
        <div class="prem-amount">
          $<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!quote.Employer_Monthly_Total__c}"/></apex:outputText>
        </div>
        <apex:outputPanel rendered="{!lineItems.size > 0}">
          <div class="prem-sub"><apex:outputText value="{!TEXT(lineItems[0].Employer_Contribution_Pct__c)}"/>% Contribution</div>
        </apex:outputPanel>
      </td>
      <td class="prem-employee">
        <div class="prem-label">Employee Monthly Cost</div>
        <div class="prem-amount">
          $<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!quote.Employee_Monthly_Total__c}"/></apex:outputText>
        </div>
      </td>
      <td class="prem-annual">
        <div class="prem-label">Total Annual Premium</div>
        <div class="prem-amount">
          $<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!quote.Total_Annual_Premium__c}"/></apex:outputText>
        </div>
      </td>
    </tr>
  </table>
</div>

<!-- PER-PLAN RATE DETAILS -->
<apex:repeat value="{!lineItems}" var="li">
<div class="plan-box">
  <div class="section-title">Plan Details</div>
  <div class="plan-name"><apex:outputText value="{!li.Plan__r.Name}"/></div>
  <table class="plan-attrs">
    <tr>
      <td>
        <span class="attr-label">Type</span>
        <span class="attr-value"><apex:outputText value="{!li.Plan__r.Plan_Type__c}"/></span>
      </td>
      <td>
        <span class="attr-label">Network</span>
        <span class="attr-value"><apex:outputText value="{!li.Plan__r.Network__c}"/></span>
      </td>
      <td>
        <span class="attr-label">Deductible (Ind / Fam)</span>
        <span class="attr-value">
          $<apex:outputText value="{0, number, #,##0}"><apex:param value="{!li.Plan__r.Deductible_Individual__c}"/></apex:outputText>
          &nbsp;/&nbsp;
          $<apex:outputText value="{0, number, #,##0}"><apex:param value="{!li.Plan__r.Deductible_Family__c}"/></apex:outputText>
        </span>
      </td>
      <td>
        <span class="attr-label">Annual Maximum</span>
        <span class="attr-value">
          <apex:outputText value="{!IF(li.Plan__r.Annual_Maximum__c = null, 'No Maximum', '$' & TEXT(li.Plan__r.Annual_Maximum__c))}"/>
        </span>
      </td>
      <td>
        <span class="attr-label">Waiting Period</span>
        <span class="attr-value"><apex:outputText value="{!li.Plan__r.Waiting_Period__c}"/></span>
      </td>
    </tr>
  </table>

  <table class="rate-tbl">
    <thead>
      <tr>
        <th>Coverage Tier</th>
        <th class="rt">Monthly Rate</th>
        <th class="rt">Subscribers</th>
        <th class="rt">Monthly Subtotal</th>
        <th class="rt">Employer Cost</th>
        <th class="rt">Employee Cost</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Employee Only (EO)</td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EO__c}"/></apex:outputText></td>
        <td class="rt"><apex:outputText value="{!TEXT(li.Count_EO__c)}"/></td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EO__c * li.Count_EO__c}"/></apex:outputText></td>
        <td class="rt emp-cost">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EO__c * li.Count_EO__c * li.Employer_Contribution_Pct__c / 100}"/></apex:outputText></td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EO__c * li.Count_EO__c * (1 - li.Employer_Contribution_Pct__c / 100)}"/></apex:outputText></td>
      </tr>
      <tr>
        <td>Employee + Spouse (ES)</td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_ES__c}"/></apex:outputText></td>
        <td class="rt"><apex:outputText value="{!TEXT(li.Count_ES__c)}"/></td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_ES__c * li.Count_ES__c}"/></apex:outputText></td>
        <td class="rt emp-cost">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_ES__c * li.Count_ES__c * li.Employer_Contribution_Pct__c / 100}"/></apex:outputText></td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_ES__c * li.Count_ES__c * (1 - li.Employer_Contribution_Pct__c / 100)}"/></apex:outputText></td>
      </tr>
      <tr>
        <td>Employee + Child(ren) (EC)</td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EC__c}"/></apex:outputText></td>
        <td class="rt"><apex:outputText value="{!TEXT(li.Count_EC__c)}"/></td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EC__c * li.Count_EC__c}"/></apex:outputText></td>
        <td class="rt emp-cost">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EC__c * li.Count_EC__c * li.Employer_Contribution_Pct__c / 100}"/></apex:outputText></td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EC__c * li.Count_EC__c * (1 - li.Employer_Contribution_Pct__c / 100)}"/></apex:outputText></td>
      </tr>
      <tr>
        <td>Employee + Family (EF)</td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EF__c}"/></apex:outputText></td>
        <td class="rt"><apex:outputText value="{!TEXT(li.Count_EF__c)}"/></td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EF__c * li.Count_EF__c}"/></apex:outputText></td>
        <td class="rt emp-cost">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EF__c * li.Count_EF__c * li.Employer_Contribution_Pct__c / 100}"/></apex:outputText></td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Rate_EF__c * li.Count_EF__c * (1 - li.Employer_Contribution_Pct__c / 100)}"/></apex:outputText></td>
      </tr>
      <tr class="plan-total">
        <td colspan="3"><strong>Plan Monthly Total</strong></td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Monthly_Subtotal__c}"/></apex:outputText></td>
        <td class="rt emp-cost">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Employer_Monthly_Cost__c}"/></apex:outputText></td>
        <td class="rt">$<apex:outputText value="{0, number, #,##0.00}"><apex:param value="{!li.Employee_Monthly_Cost__c}"/></apex:outputText></td>
      </tr>
    </tbody>
  </table>
</div>
</apex:repeat>

<!-- NOTES -->
<apex:outputPanel rendered="{!NOT(ISBLANK(quote.Notes__c))}">
<div class="section">
  <div class="section-title">Notes</div>
  <div class="notes-box"><apex:outputText value="{!quote.Notes__c}"/></div>
</div>
</apex:outputPanel>

<!-- FOOTER -->
<div class="footer">
  <div class="footer-legal">
    This proposal was prepared by Delta Dental of California and is valid through
    <apex:outputText value="{!expirationFormatted}"/>.
    Rates are subject to final underwriting approval. This is not a contract of insurance.
    For questions, contact your Delta Dental representative.
  </div>
  <div class="footer-ref">
    Quote #<apex:outputText value="{!quote.Name}"/> &bull;
    Generated <apex:outputText value="{!todayFormatted}"/> &bull;
    Delta Dental of California &bull; CONFIDENTIAL
  </div>
</div>

</body>
</html>
</apex:page>
