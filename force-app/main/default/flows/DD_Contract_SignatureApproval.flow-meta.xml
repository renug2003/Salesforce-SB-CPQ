<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <description>Record-triggered flow. When Is_Signed__c is set to true and Signed_Date__c is populated, automatically updates contract Status to Approved.</description>
    <environments>Default</environments>
    <interviewLabel>DD Contract Signature Approval {!$Flow.CurrentDateTime}</interviewLabel>
    <label>DD Contract Signature Approval</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value><stringValue>LightningFlowBuilder</stringValue></value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>176</locationX>
        <locationY>48</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Is_Signed__c</field>
            <operator>EqualTo</operator>
            <value><booleanValue>true</booleanValue></value>
        </filters>
        <filters>
            <field>Signed_Date__c</field>
            <operator>IsNull</operator>
            <value><booleanValue>false</booleanValue></value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>NotEqualTo</operator>
            <value><stringValue>Approved</stringValue></value>
        </filters>
        <object>DD_Contract__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <scheduledPaths>
            <connector>
                <targetReference>Update_Contract_Status_Approved</targetReference>
            </connector>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
    </start>
    <status>Active</status>
    <recordUpdates>
        <description>Set contract status to Approved when signed</description>
        <name>Update_Contract_Status_Approved</name>
        <label>Update Status to Approved</label>
        <locationX>176</locationX>
        <locationY>200</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Status__c</field>
            <value><stringValue>Approved</stringValue></value>
        </inputAssignments>
        <object>DD_Contract__c</object>
    </recordUpdates>
</Flow>
